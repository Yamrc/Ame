<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product
    Id="$(var.ProductCode)"
    Name="Ame"
    Language="2052"
    Codepage="936"
    Version="$(var.ProductVersion)"
    Manufacturer="NeoNekos"
    UpgradeCode="A5231D3F-2ED7-4E43-8F87-ECE918F16F58">
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      InstallPrivileges="elevated"
      Languages="2052"
      SummaryCodepage="936"
      Platform="x64" />

    <MajorUpgrade
      AllowDowngrades="no"
      DowngradeErrorMessage="!(loc.DowngradeErrorMessage)" />

    <MediaTemplate EmbedCab="yes" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="ADD_START_MENU_SHORTCUT" Value="1" />
    <Property Id="REMOVE_APPDATA" Value="1" />
    <Property Id="APPDATADIR" Secure="yes" />
    <SetProperty Id="APPDATADIR" Value="[AppDataFolder]Ame" Before="CostFinalize">NOT APPDATADIR</SetProperty>
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_Common" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <UI>
      <Dialog Id="AmeOptionsDlg" Width="370" Height="270" Title="!(loc.OptionsDialogTitle)">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.OptionsDialogTitle)" />
        <Control Id="Description" Type="Text" X="15" Y="24" Width="340" Height="30" Transparent="yes" NoPrefix="yes" Text="!(loc.OptionsDialogDescription)" />

        <Control Id="StartMenuCheckbox" Type="CheckBox" X="20" Y="70" Width="330" Height="18"
          Property="ADD_START_MENU_SHORTCUT" CheckBoxValue="1" Text="!(loc.OptionsStartMenuShortcut)" />
        <Control Id="RemoveAppDataCheckbox" Type="CheckBox" X="20" Y="92" Width="330" Height="18"
          Property="REMOVE_APPDATA" CheckBoxValue="1" Text="!(loc.OptionsRemoveAppData)" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg">1</Publish>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>

      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="AmeOptionsDlg">1</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="AmeOptionsDlg">1</Publish>
    </UI>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Ame">
          <Component Id="cmpAmeExe" Guid="20A28881-6A4E-4DAC-BFC2-B33D3E464BB7" Win64="yes">
            <File Id="filAmeExe" Source="$(var.SourceExe)" KeyPath="yes" />
          </Component>
          <Component Id="cmpAmeRegistry" Guid="EC3AC082-346A-48E4-A076-C9048B017527" Win64="yes">
            <RegistryKey Root="HKLM" Key="Software\NeoNekos\Ame">
              <RegistryValue Name="InstallDir" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
              <RegistryValue Name="Version" Type="string" Value="$(var.ProductVersion)" />
            </RegistryKey>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AmeProgramMenuFolder" Name="Ame">
          <Component Id="cmpStartMenuShortcut" Guid="B635F98E-E7A7-4B5B-B988-FB15CDAF5FC5" Win64="yes">
            <Condition>ADD_START_MENU_SHORTCUT=1</Condition>
            <Shortcut
              Id="AmeStartMenuShortcut"
              Name="Ame"
              Description="Ame"
              Target="[INSTALLFOLDER]ame.exe"
              WorkingDirectory="INSTALLFOLDER" />
            <RemoveFolder Id="RemoveAmeProgramMenuFolder" On="uninstall" />
            <RegistryValue
              Root="HKCU"
              Key="Software\NeoNekos\Ame"
              Name="StartMenuShortcut"
              Type="integer"
              Value="1"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
      <Directory Id="AppDataFolder">
        <Component Id="cmpAppDataCleanup" Guid="AE147EC6-AAD2-4252-8D61-65AF2A6FD931" Win64="yes">
          <Condition>REMOVE_APPDATA=1</Condition>
          <RegistryValue
            Root="HKCU"
            Key="Software\NeoNekos\Ame"
            Name="AppDataDir"
            Type="string"
            Value="[APPDATADIR]"
            KeyPath="yes" />
          <util:RemoveFolderEx Id="RemoveAppData" On="uninstall" Property="APPDATADIR" />
        </Component>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="Ame" Level="1">
      <ComponentRef Id="cmpAmeExe" />
      <ComponentRef Id="cmpAmeRegistry" />
      <ComponentRef Id="cmpStartMenuShortcut" />
      <ComponentRef Id="cmpAppDataCleanup" />
    </Feature>
  </Product>
</Wix>
